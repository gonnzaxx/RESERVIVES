# ============================================================
# RESERVIVES - Variables de entorno
# ============================================================

# Base de datos PostgreSQL
POSTGRES_DB=nombre_bd
POSTGRES_USER=usuario
POSTGRES_PASSWORD=contraseña
DATABASE_URL=postgresql+asyncpg://usuario:contraseña@db:5432/nombre_bd

# Servidor
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Microsoft EntraID (OAuth2)
AZURE_CLIENT_ID=tu-client-id
AZURE_TENANT_ID=tu-tenant-id
AZURE_CLIENT_SECRET=tu-client-secret
AZURE_AUTHORITY=https://login.microsoftonline.com/tu-tenant-id

# JWT para sesiones internas
JWT_SECRET_KEY=tu-clave-secreta
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dominios permitidos para registro
ALLOWED_DOMAINS=alumno.iesluisvives.org,profesor.iesluisvives.org,iesluisvives.org

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000,http://localhost,http://127.0.0.1,http://localhost:2121

# Tokens mensuales para alumnos
DEFAULT_MONTHLY_TOKENS=20


# Emails de notificaciones
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-correo@gmail.com
SMTP_PASSWORD=tu-contraseña-de-aplicación
SMTP_FROM_EMAIL=tu-correo@gmail.com

# Firebase Cloud Messaging
FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=firebase-credentials.example.json
FIREBASE_WEB_APP_URL=http://localhost:3000

# IA (Gemini)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash
